{
  "manifest_version": 2,
  "name": "HC Suggest",
  "version": "0.1.0",
  "description": "Cart-aware staffing suggester for IND8 FRACS (Pick / Rebin / Pack). Uses per-AA learned rates from FCLM and live cart-level backlog from Rodeo.",
  "author": "Ca3de",
  "homepage_url": "https://github.com/Ca3de/HCSugest",

  "browser_specific_settings": {
    "gecko": {
      "id": "hcsugest@ca3de.github.io",
      "strict_min_version": "109.0"
    }
  },

  "permissions": [
    "storage",
    "tabs",
    "*://rodeo-iad.amazon.com/*",
    "*://fclm-portal.amazon.com/*",
    "https://hooks.slack.com/*"
  ],

  "background": {
    "scripts": [
      "lib/paths.js",
      "lib/cache.js",
      "lib/rodeo.js",
      "lib/fclm.js",
      "lib/optimizer.js",
      "lib/slack.js",
      "background.js"
    ],
    "persistent": false
  },

  "browser_action": {
    "default_title": "HC Suggest",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "32": "icons/icon.svg",
      "48": "icons/icon.svg"
    }
  },

  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
